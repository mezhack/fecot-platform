# ============================================
# FECOT Backend — Variáveis de Ambiente
# ============================================
# Copie este arquivo para `.env` e ajuste os valores.
# NUNCA commite o `.env` real no git.

# --- App ---
APP_NAME=FECOT Platform API
APP_ENV=development       # development | production
DEBUG=true

# --- Servidor ---
HOST=0.0.0.0
PORT=3002

# --- Database ---
# Formato: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg2://fecot:fecot@localhost:5432/fecot_dev

# --- JWT ---
# Em produção, gere um segredo forte:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=troque-este-segredo-em-producao-com-64-caracteres-aleatorios
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 horas

# --- CORS ---
# Lista separada por vírgula. Em produção, coloque apenas seu domínio.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Uploads (avatares) ---
# Em dev, pasta relativa (dentro do container / do projeto).
# Em prod na Hostinger: /var/lib/fecot/uploads (criar com mkdir -p + chown)
UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_PREFIX=/uploads
AVATAR_MAX_MB=5
AVATAR_MAX_SIZE=512
